# Calorie Coach dashboard — environment variables
# Copy this file to `.env.local` and fill in real values.

# One API secret — the bearer used to auth every request going through
# One's passthrough (connection list + Notion query). Create at
# https://app.withone.ai/settings/api-keys
ONE_SECRET=sk_live_xxx

# Notion data source ID for the Meals database — the dashboard queries this.
# You can find it in the URL of the database page in Notion, OR by running
# `one --agent actions search notion "search"` + querying the DB from the
# meal-logger skill's create-database response.
NOTION_MEALS_DATA_SOURCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Notion data source ID for the Targets database — single Active row holds
# the user's daily macro targets plus the Pending Field/Value/Reason
# columns the agent uses for the YES/NO flow. Dashboard reads from here;
# the `weekly-recap` and `apply-targets` skills both write here.
NOTION_TARGETS_DATA_SOURCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: Telegram bot handle to display on the /station "how to begin" panel.
# Format: @your_bot_name. If unset, the panel says "your Telegram bot".
# NEXT_PUBLIC_TELEGRAM_BOT_HANDLE=@your_bot_handle
